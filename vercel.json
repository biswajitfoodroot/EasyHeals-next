{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/outbox",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/previsit-briefs",
      "schedule": "0 6 * * *"
    }
  ]
}
